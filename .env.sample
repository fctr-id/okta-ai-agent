# ===================================================================
#  PART 1: OKTA CONFIGURATION (REQUIRED)
# ===================================================================

# 1. Your Okta organization URL (format: https://your-domain.okta.com)
OKTA_CLIENT_ORGURL=https://your-domain.okta.com

# 2. Authentication method. Options: API_TOKEN or OAUTH2
# To use OAuth2, change this to OAUTH2 and configure the OAuth2 section below.
TOKEN_METHOD=API_TOKEN

# 3. Okta API Token (required when TOKEN_METHOD=API_TOKEN)
OKTA_API_TOKEN=

# 4. Concurrent API request limit
# Default: 18 (safe baseline for lower-rate-limit tenants)
OKTA_CONCURRENT_LIMIT=18

# Note: legacy aliases such as OKTA_ORG_URL and SSWS_API_KEY are still
# accepted in code for backward compatibility, but this sample only shows
# the canonical variable names.


# ===================================================================
#  PART 2: AI PROVIDER CONFIGURATION (REQUIRED)
# ===================================================================

# Set AI_PROVIDER to one of:
# google, openai, anthropic, vertex_ai, azure_openai, openai_compatible, bedrock
AI_PROVIDER=openai

# -------------------------------------------------------------------
#  Fill ONLY the section matching your AI_PROVIDER choice
# -------------------------------------------------------------------

# --- OPTION A: OpenAI ---
OPENAI_API_KEY=
OPENAI_REASONING_MODEL=gpt-5.4
OPENAI_CODING_MODEL=gpt-5.4-mini

# --- OPTION B: Google AI Studio ---
GOOGLE_API_KEY=
GOOGLE_REASONING_MODEL=gemini-2.5-pro
GOOGLE_CODING_MODEL=gemini-2.5-pro

# --- OPTION C: Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_REASONING_MODEL=claude-sonnet-4-6
ANTHROPIC_CODING_MODEL=claude-haiku-4-5

# --- OPTION D: Vertex AI ---
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=global
VERTEX_AI_SERVICE_ACCOUNT_FILE=path/to/service-account.json
# Optional fallback used by the model loader if VERTEX_AI_SERVICE_ACCOUNT_FILE is unset or invalid
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_REASONING_MODEL=gemini-3-pro
VERTEX_AI_CODING_MODEL=gemini-3-flash-preview

# --- OPTION E: Azure OpenAI ---
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://xxxxxx.cognitiveservices.azure.com/
AZURE_OPENAI_VERSION=2024-07-08
AZURE_OPENAI_REASONING_MODEL=gpt-4o
AZURE_OPENAI_CODING_MODEL=gpt-4o

# --- OPTION F: AWS Bedrock ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
BEDROCK_REASONING_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_CODING_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0

# --- OPTION G: OpenAI-Compatible APIs (Ollama / local / proxy) ---
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_TOKEN=ollama
OPENAI_COMPATIBLE_REASONING_MODEL=llama3
OPENAI_COMPATIBLE_CODING_MODEL=llama3


# ===================================================================
#  PART 3: OPTIONAL / ADVANCED SETTINGS
# ===================================================================

# --- Runtime Storage Paths ---
DB_DIR=sqlite_db
DB_FILENAME=okta_sync.db
CHAT_SESSIONS_DIR=chat_sessions

# --- Sync Configuration ---
# Comma-separated list of additional Okta profile attributes to sync
OKTA_USER_CUSTOM_ATTRIBUTES=

# Deprovisioned users are included by default.
# If both dates are blank: all deprovisioned users are synced.
# If dates are set: users must satisfy both conditions.
SYNC_DEPROVISIONED_USERS=true
DEPR_USER_CREATED_AFTER=
DEPR_USER_UPDATED_AFTER=

# Device sync is disabled by default because it is slower and more API-intensive.
SYNC_OKTA_DEVICES=false

# --- OAuth2 Configuration (required when TOKEN_METHOD=OAUTH2) ---
OKTA_OAUTH2_CLIENT_ID=
OKTA_OAUTH2_SCOPES="okta.agentPools.read okta.appGrants.read okta.apps.read okta.authModes.read okta.authenticators.read okta.authorizationServers.read okta.behaviors.read okta.brands.read okta.captchas.read okta.certificateAuthorities.read okta.clients.read okta.deviceAssurance.read okta.devices.read okta.domains.read okta.emailDomains.read okta.emailServers.read okta.enduser.dashboard.read okta.enduser.read okta.eventHooks.read okta.events.read okta.factors.read okta.groups.read okta.identitySources.read okta.idps.read okta.inlineHooks.read okta.linkedObjects.read okta.logStreams.read okta.logs.read okta.manifests.read okta.networkZones.read okta.orgs.read okta.policies.read okta.principalRateLimits.read okta.profileMappings.read okta.pushProviders.read okta.rateLimits.read okta.reports.read okta.riskProviders.read okta.roles.read okta.schemas.read okta.securityEventsProviders.read okta.sessions.read okta.templates.read okta.threatInsights.read okta.trustedOrigins.read okta.uischemas.read okta.userTypes.read okta.users.read"
OKTA_OAUTH2_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"

# --- Security, Cookies, and SSL ---
# Change JWT_SECRET_KEY in any shared or production-like environment.
JWT_SECRET_KEY=CHANGE-THIS-KEY-IN-PRODUCTION-ENVIRONMENTS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=fctr-okta-ai-agent
JWT_AUDIENCE=ui-user

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE_MINUTES=30

VERIFY_SSL=true
# SSL_CA_BUNDLE_FILENAME=custom-trust-certs.pem

# Optional: override CORS origins instead of using the default local HTTPS origins.
# ALLOWED_ORIGINS=https://localhost:3000,https://127.0.0.1:3000

# --- Application Tuning and Observability ---
LOG_LEVEL=INFO
FILE_LOG_LEVEL=DEBUG
MAX_TOOL_CALLS=30
# API_PROGRESS_MAX_EVENTS=20
# OKTA_METRICS_PATH=logs/metrics

# Custom headers for OpenAI-compatible/local providers behind proxies or gateways.
# CUSTOM_HTTP_HEADERS={"Header-Name": "Header Value"}

# --- Slack Bot Integration (optional) ---
ENABLE_SLACK_BOT=false

# How Slack delivers events to Tako:
#   socket  - outbound WebSocket to Slack (no public URL needed)
#   http    - Slack POSTs to /slack/events (requires a public HTTPS URL)
SLACK_OPERATION_MODE=socket

# Slack app credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Slack access control (deny by default)
SLACK_ALLOWED_EMAILS=
SLACK_ALLOWED_GROUPS=
SLACK_ALLOW_ALL_USERS=false

